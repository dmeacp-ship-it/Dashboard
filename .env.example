# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
# Optional: lock CORS to a specific origin (defaults to *)
# CORS_ORIGIN=https://your-app.example.com

# ── Supabase (required) ───────────────────────────────────────────────────────
# Same project URL + service key you used in the Apps Script Script Properties.
# The app reads the same views/tables: vw_monthly_agg, vw_hod_agg,
# vw_customer_summary, vw_customer_sale_agg, vw_sku_type_sale_agg, vw_brand_agg,
# vw_sku_agg, vw_outstanding_hod, target_master, user_profiles, etc.
SUPABASE_URL=
SUPABASE_KEY=

# ── AI (optional — Copilot / Ask-AI) ──────────────────────────────────────────
# Either naming works; *_API_KEY takes precedence (matches the original GAS keys).
GEMINI_API_KEY=
GROQ_API_KEY=
# GEMINI_KEY=
# GROQ_KEY=

# ── Google Sheets sync (optional — only for the Settings > Sync buttons) ───────
# Paste the FULL service-account JSON on one line, then share every source
# sheet (RAW DATA, CUSTOMER MASTER, TARGET_DATA) with the service-account email.
GOOGLE_SERVICE_ACCOUNT_JSON=
